{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": [
		"./src/**/*.ts"
	],
	"exclude": [
		"./node_modules/**/*",
		"./**/*.test.ts",
		"./**/*.contract.ts",
		"./**/__mocks__/**/*",
		"./**/__tests__/**/*",
		"./**/__fixtures__/**/*"
	],
	"json": "./resource/doc/api/docs.json",
	"out": "./resource/doc/api",
	"plugin": [
		"typedoc-plugin-markdown"
	],
	"readme": "none"
}
